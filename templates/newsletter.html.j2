{#
  Newsletter template (Jinja2). Renders one HTML page per Scholar Inbox digest.
  Loaded by scripts/render_html.py.

  Per-paper variables expected (filled in by render_html.py):
    p.rank              int
    p.score             float | None
    p.score_class       'score-high' | 'score-mid' | 'score-low' | ''
    p.score_text        e.g. "0.96"
    p.method_shortname  str | None
    p.title             str
    p.scholar_inbox_url str    (title links here so user can like/dislike)
    p.source_url        str    (CVPR / arXiv abs page)
    p.pdf_url, p.github_url, p.project_url, p.arxiv_id
    p.paper_id          str    (used as data-paper-id for rating buttons)
    p.rating            -1 | 0 | 1   (initial state for buttons)
    p.authors           str
    p.venue             str
    p.struct_en         [{label, bullets:[html]}, ...] | None
    p.struct_ja         [{label, bullets:[html]}, ...] | None
    p.abstract_short    str | None       (fallback when no struct)
    p.figures           [{url, caption}, ...]   (0, 1, or 2 entries: teaser + arch)

  Section order: title → byline → figure(s) → EN summary → JA summary → links.
  Like / dislike buttons live in the title row next to the score badge; they
  call the Scholar Inbox `make_rating` API from the browser (requires the
  reader to be logged into scholar-inbox.com in the same browser).
#}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Scholar Inbox digest — {{ date or "today" }}</title>
<style>
  :root {
    --fg: #1a1a1a;
    --muted: #6a6a6a;
    --soft: #e6e6e6;
    --link: #0a55c4;
    --section: #7a4a00;
    --section-ja: #4a4a4a;
    --score-high-bg: #d8f0e3;
    --score-high-fg: #14693e;
    --score-mid-bg:  #fbeacd;
    --score-mid-fg:  #8a5300;
    --score-low-bg:  #ececec;
    --score-low-fg:  #555;
    --like-on:   #14693e;
    --dislike-on:#a62828;
  }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         max-width: 860px; margin: 32px auto; padding: 0 18px; color: var(--fg);
         line-height: 1.55; -webkit-font-smoothing: antialiased; }
  header.page { margin-bottom: 28px; }
  header.page h1 { font-size: 24px; margin: 0 0 4px; letter-spacing: -0.01em; }
  header.page .meta { color: var(--muted); font-size: 13px; }
  header.page .note { color: var(--muted); font-size: 12px; margin-top: 6px;
                      padding: 6px 10px; background: #f6f6f6; border-radius: 4px;
                      display: inline-block; }

  article.paper { border-top: 1px solid var(--soft); padding: 24px 0 30px; }
  article.paper:first-of-type { border-top: none; padding-top: 8px; }

  /* Title row: title block on the left, score badge + rate buttons on the right. */
  .paper-head { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 12px; }
  .title-wrap { flex: 1; min-width: 0; }
  .rank { display: inline-block; min-width: 26px; color: var(--muted); font-size: 13px;
          font-variant-numeric: tabular-nums; }
  .title { font-size: 17px; font-weight: 600; margin: 0 0 4px; }
  .title a { color: var(--fg); text-decoration: none; }
  .title a:hover { text-decoration: underline; }
  .shortname { color: #b34800; font-weight: 700; margin-right: 6px; }
  .byline { color: var(--muted); font-size: 13px; margin: 0 0 0 26px; }

  /* Right column: score badge stacked above the rate buttons. */
  .head-actions { display: flex; flex-direction: column; align-items: stretch;
                  gap: 6px; flex: 0 0 auto; }
  .score-badge { min-width: 64px; text-align: center;
                 font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums;
                 padding: 6px 12px; border-radius: 6px; line-height: 1.1;
                 letter-spacing: -0.01em; }
  .score-badge .score-label { display: block; font-size: 9px; font-weight: 600;
                              letter-spacing: 0.12em; text-transform: uppercase;
                              opacity: 0.7; margin-top: 2px; }
  .score-high { background: var(--score-high-bg); color: var(--score-high-fg); }
  .score-mid  { background: var(--score-mid-bg);  color: var(--score-mid-fg); }
  .score-low  { background: var(--score-low-bg);  color: var(--score-low-fg); }

  .rate-buttons { display: flex; gap: 4px; justify-content: center; }
  .rate-btn { flex: 1; cursor: pointer; border: 1px solid var(--soft); background: #fff;
              color: var(--muted); padding: 4px 0; border-radius: 4px;
              font-size: 16px; line-height: 1; transition: background 0.1s, color 0.1s; }
  .rate-btn:hover { background: #f4f4f4; }
  .rate-btn:active { transform: translateY(1px); }
  .paper[data-rating="1"]  .rate-btn-like    { background: var(--score-high-bg);
                                                color: var(--like-on); border-color: var(--like-on); }
  .paper[data-rating="-1"] .rate-btn-dislike { background: #f6dada;
                                                color: var(--dislike-on); border-color: var(--dislike-on); }
  .rate-btn.busy { opacity: 0.5; pointer-events: none; }
  .rate-btn.err  { border-color: var(--dislike-on); color: var(--dislike-on); }

  .body { margin-left: 26px; }

  /* Figures come first; up to 2 side by side on wide, stacked on narrow. */
  .figures { display: flex; flex-wrap: wrap; gap: 12px; margin: 4px 0 14px; }
  .figures figure { flex: 1 1 360px; margin: 0; min-width: 0; }
  .figures img { width: 100%; height: auto; border: 1px solid var(--soft);
                 border-radius: 4px; display: block; }
  .figures figcaption { color: var(--muted); font-size: 12px; margin-top: 6px;
                        line-height: 1.4; }
  .nofig { color: #a0a0a0; font-size: 12px; font-style: italic; margin: 4px 0 12px; }

  /* English structured summary. */
  .struct { font-size: 14px; margin: 6px 0 8px; }
  .struct .sec { margin: 6px 0; padding: 0; }
  .struct .sec-h { font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
                   text-transform: uppercase; color: var(--section); margin: 0 0 2px; }
  .struct ul { margin: 2px 0 6px; padding-left: 20px; }
  .struct li { margin: 2px 0; }

  /* Japanese mirror. */
  .struct-ja { font-size: 13.5px; margin: 4px 0 10px; color: #2a2a2a;
               border-left: 2px solid #d9d9d9; padding: 4px 0 4px 12px; }
  .struct-ja .sec { margin: 4px 0; }
  .struct-ja .sec-h { font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
                      color: var(--section-ja); margin: 0 0 2px; }
  .struct-ja ul { margin: 2px 0 4px; padding-left: 18px; }
  .struct-ja li { margin: 2px 0; }

  .abstract-fallback { font-size: 13px; color: #555; margin: 6px 0 10px; }

  .links { font-size: 13px; margin-top: 8px; }
  .links a { color: var(--link); text-decoration: none; margin-right: 14px; }
  .links a:hover { text-decoration: underline; }

  /* Toast for like/dislike feedback errors. */
  #toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
           background: #2a2a2a; color: #fff; padding: 10px 16px; border-radius: 4px;
           font-size: 13px; opacity: 0; pointer-events: none;
           transition: opacity 0.2s; z-index: 1000; max-width: 80%; }
  #toast.show { opacity: 1; }
</style>
</head>
<body>
<header class="page">
  <h1>Scholar Inbox digest</h1>
  <div class="meta">
    {% if date %}{{ date }} · {% endif %}
    {% if user %}for {{ user }} · {% endif %}
    {{ papers|length }} papers
  </div>
  <div class="note">
    Click 👍 / 👎 to rate. Requires being logged in to
    <a href="https://www.scholar-inbox.com" target="_blank">scholar-inbox.com</a>
    in this browser.
  </div>
</header>

{% for p in papers %}
<article class="paper" data-paper-id="{{ p.paper_id }}" data-rating="{{ p.rating }}">
  <div class="paper-head">
    <div class="title-wrap">
      <h2 class="title">
        <span class="rank">{{ p.rank }}.</span>
        {% if p.method_shortname %}<span class="shortname">{{ p.method_shortname }}:</span>{% endif %}
        {% if p.scholar_inbox_url %}<a href="{{ p.scholar_inbox_url }}">{{ p.title }}</a>{% else %}{{ p.title }}{% endif %}
      </h2>
      <div class="byline">
        {{ p.authors }}{% if p.venue %} · {{ p.venue }}{% endif %}
      </div>
    </div>
    <div class="head-actions">
      {% if p.score is not none %}
      <div class="score-badge {{ p.score_class }}">
        {{ p.score_text }}
        <span class="score-label">match</span>
      </div>
      {% endif %}
      {% if p.paper_id %}
      <div class="rate-buttons">
        <button class="rate-btn rate-btn-like"    type="button" title="Like">👍</button>
        <button class="rate-btn rate-btn-dislike" type="button" title="Dislike">👎</button>
      </div>
      {% endif %}
    </div>
  </div>

  <div class="body">
    {% if p.figures %}
    <div class="figures">
      {% for f in p.figures %}
      <figure>
        <img src="{{ f.url }}" alt="{{ (f.caption or '')[:80] }}">
        {% if f.caption %}<figcaption>{{ f.caption }}</figcaption>{% endif %}
      </figure>
      {% endfor %}
    </div>
    {% else %}
    <div class="nofig">(no figure available)</div>
    {% endif %}

    {% if p.struct_en %}
    <div class="struct">
      {% for s in p.struct_en %}
      <div class="sec">
        <div class="sec-h">{{ s.label }}</div>
        <ul>{% for b in s.bullets %}<li>{{ b|safe }}</li>{% endfor %}</ul>
      </div>
      {% endfor %}
    </div>
    {% elif p.abstract_short %}
    <p class="abstract-fallback">{{ p.abstract_short }}</p>
    {% endif %}

    {% if p.struct_ja %}
    <div class="struct-ja">
      {% for s in p.struct_ja %}
      <div class="sec">
        <div class="sec-h">{{ s.label }}</div>
        <ul>{% for b in s.bullets %}<li>{{ b|safe }}</li>{% endfor %}</ul>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <div class="links">
      {% if p.scholar_inbox_url %}<a href="{{ p.scholar_inbox_url }}">scholar-inbox</a>{% endif %}
      {% if p.source_url %}<a href="{{ p.source_url }}">paper</a>{% endif %}
      {% if p.pdf_url and p.pdf_url != p.source_url %}<a href="{{ p.pdf_url }}">pdf</a>{% endif %}
      {% if p.github_url %}<a href="{{ p.github_url }}">code</a>{% endif %}
      {% if p.project_url %}<a href="{{ p.project_url }}">project</a>{% endif %}
      {% if p.arxiv_id %}<a href="https://arxiv.org/abs/{{ p.arxiv_id }}">arXiv</a>{% endif %}
    </div>
  </div>
</article>
{% endfor %}

<div id="toast" role="status" aria-live="polite"></div>

<script>
// Like / dislike via Scholar Inbox's /api/make_rating/ endpoint.
// Works only when the reader is signed in to scholar-inbox.com in this
// browser (the request is sent with credentials so the session cookie on
// .scholar-inbox.com is included; the API server allows the null origin
// of file:// pages).
const RATE_URL = "https://api.scholar-inbox.com/api/make_rating/";

const toast = document.getElementById("toast");
function flash(msg, ms=3500) {
  toast.textContent = msg;
  toast.classList.add("show");
  clearTimeout(flash._t);
  flash._t = setTimeout(() => toast.classList.remove("show"), ms);
}

async function setRating(article, btn, newRating) {
  const pid = article.dataset.paperId;
  const prev = article.dataset.rating;
  btn.classList.add("busy");
  try {
    const r = await fetch(RATE_URL, {
      method: "POST",
      credentials: "include",
      headers: {"content-type": "application/json"},
      body: JSON.stringify({rating: newRating, id: String(pid)}),
    });
    if (!r.ok) throw new Error("HTTP " + r.status);
    article.dataset.rating = String(newRating);
  } catch (e) {
    btn.classList.add("err");
    setTimeout(() => btn.classList.remove("err"), 1500);
    flash("Rating failed (" + e.message + "). Make sure you are signed in to scholar-inbox.com in this browser.");
    article.dataset.rating = prev;  // revert
  } finally {
    btn.classList.remove("busy");
  }
}

document.querySelectorAll(".rate-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    const article = btn.closest(".paper");
    const cur = parseInt(article.dataset.rating || "0", 10);
    const target = btn.classList.contains("rate-btn-like") ? 1 : -1;
    const newRating = (cur === target) ? 0 : target;
    setRating(article, btn, newRating);
  });
});
</script>
</body>
</html>
